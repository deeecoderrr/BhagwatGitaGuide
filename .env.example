DEBUG=true
SECRET_KEY=replace-with-secure-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=

# Shown in chat UI support panel; default sender for signup / password-reset mail.
SUPPORT_EMAIL=askbhagwatgitasupport@gmail.com
DEFAULT_FROM_EMAIL=askbhagwatgitasupport@gmail.com

# Required on production for email signup verification & forgot-password mail:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=askbhagwatgitasupport@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Set true to use local Ollama for chat/JSON guidance (Responses API calls map to chat.completions).
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# Must match a name from `ollama list` (e.g. gemma4:latest).
OLLAMA_MODEL=gemma4:latest
# Extra LLM: commentary-aware verse relevance after retrieval (set true to skip).
DISABLE_VERSE_RELEVANCE_LLM=false
# If no verses remain, optional LLM to suggest chapter.verse refs (set true to skip).
DISABLE_LLM_VERSE_SUGGEST_WHEN_EMPTY=false
# Optional: cheaper model for intent JSON only (defaults to OPENAI_MODEL)
OPENAI_INTENT_MODEL=
# Default true: skip extra intent JSON (heuristics first). Set false for edge-case routing.
DISABLE_INTENT_LLM_REFINEMENT=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Enrich query embeddings with life-domain + themes from interpret_query (recommended).
OPENAI_QUERY_EMBEDDING_ENRICHED=true
OPENAI_EMBEDDING_QUERY_MAX_CHARS=8000
# Cache identical query embeddings (reduces embedding API spend; use Redis CACHES in prod if multi-worker).
OPENAI_QUERY_EMBEDDING_CACHE_ENABLED=true
OPENAI_QUERY_EMBEDDING_CACHE_TTL_SECONDS=86400
# Optional cheaper models for short verse JSON tasks (empty = use OPENAI_MODEL).
OPENAI_VERSE_RELEVANCE_MODEL=
OPENAI_VERSE_SUGGEST_MODEL=
# Guidance prompt: recent turns and max chars for conversation block (saves input tokens).
MAX_CONVERSATION_CONTEXT_TURNS=6
MAX_CONVERSATION_CONTEXT_CHARS=4000
ENABLE_SEMANTIC_RETRIEVAL=true
ENABLE_PGVECTOR_RETRIEVAL=false
PGVECTOR_TABLE=guide_api_verse_embedding_index
PGVECTOR_EMBEDDING_DIM=1536
PGVECTOR_PROBES=10
DISABLE_ALL_QUOTAS=false
ASK_LIMIT_FREE_DAILY=3
ASK_LIMIT_PLUS_DAILY=0
ASK_LIMIT_PRO_DAILY=0
ASK_LIMIT_FREE_MONTHLY=100
ASK_LIMIT_PLUS_MONTHLY=200
ASK_LIMIT_PRO_MONTHLY=500
ENABLE_FREE_DEEP_MODE=false
ASK_LIMIT_PLUS_DEEP_MONTHLY=40
ASK_LIMIT_PRO_DEEP_MONTHLY=180

# Per-plan LLM output token caps (controls cost per ask)
MAX_OUTPUT_TOKENS_FREE=500
MAX_OUTPUT_TOKENS_PLUS=800
MAX_OUTPUT_TOKENS_PRO=1200

# Per-plan retrieval context verse limits
MAX_CONTEXT_VERSES_FREE=3
MAX_CONTEXT_VERSES_PLUS=5
MAX_CONTEXT_VERSES_PRO=6

# Hard caps to prevent runaway LLM cost
MAX_ASK_INPUT_CHARS=2200
MAX_ASK_ACTIONS=3
MAX_VERSE_REFERENCES=3

# Razorpay Payment Settings (for subscription payments)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Pricing in smallest currency unit (paise for INR, cents for USD)
SUBSCRIPTION_PRICE_PLUS_INR=19900
SUBSCRIPTION_PRICE_PLUS_USD=349
SUBSCRIPTION_PRICE_PRO_INR=49900
SUBSCRIPTION_PRICE_PRO_USD=849

# Guided sadhana cycle (same Razorpay checkout — use product=sadhana_cycle when ordering)
SADHANA_CYCLE_DURATION_DAYS=30
SADHANA_CYCLE_PRICE_INR=29900
SADHANA_CYCLE_PRICE_USD=499

# Sign in with Google — create OAuth 2.0 Client ID (Web application) in
# Google Cloud Console, add authorized JS origins (e.g. https://askbhagavadgita.co.in)
# and authorized redirect URIs if required by your console setup.
GOOGLE_OAUTH_CLIENT_ID=your-project-id.apps.googleusercontent.com

# Optional: Google Search Console URL-prefix verification token
# Example: google-site-verification=abc123 from Search Console HTML tag method
GOOGLE_SITE_VERIFICATION=

# --- ITR Summary Generator (optional; requires ITR deps in requirements.txt)
# Set false for Bhagavad-Gita-only deploy (no allauth / ITR apps / ITR URLs).
ITR_ENABLED=true
# URL prefix for ITR routes (no trailing slash in env is OK; normalized at runtime).
ITR_URL_PREFIX=/itr-computation
# Hours summary PDF remains downloadable; then blob removed (rows stay as "expired").
ITR_OUTPUT_RETENTION_HOURS=24
# Delete uploaded JSON from storage after a successful PDF export (privacy/storage).
ITR_DELETE_INPUT_AFTER_EXPORT=true
# Beta: anonymous JSON→PDF try strip on ITR homepage; files not retained after download.
# Unset: follows DEBUG (on in local dev, off in production). Set true|false to override.
# ITR_BETA_RELEASE=true
# Max anonymous beta documents tracked in-session per browser (each upload counts until cleared).
# ITR_ANONYMOUS_MAX_DOCS_PER_SESSION=8
# Optional: separate Razorpay webhook secret for ITR billing (else falls back).
# ITR_RAZORPAY_WEBHOOK_SECRET=
# Google OAuth for django-allauth / ITR "Continue with Google" (optional).
# Needs Web application OAuth client id + secret from Google Cloud Console (same pair).
# GOOGLE_CLIENT_ID=...          # optional alias; else GOOGLE_OAUTH_CLIENT_ID is used
# GOOGLE_CLIENT_SECRET=...      # required for the button to appear (not just GIS client id)
# GOOGLE_OAUTH_CLIENT_SECRET=...  # optional alias for GOOGLE_CLIENT_SECRET
# django-allauth email verification: none | optional | mandatory (default none so
# signup works without SMTP; set optional/mandatory when outbound email is configured).
# ACCOUNT_EMAIL_VERIFICATION=none
# Redis URL for django-rq background jobs (import pipeline); sync fallback if unavailable.
# REDIS_URL=redis://127.0.0.1:6379/0
