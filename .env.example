DEBUG=true
SECRET_KEY=replace-with-secure-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional: cheaper model for intent JSON only (defaults to OPENAI_MODEL)
OPENAI_INTENT_MODEL=
# Default true: skip extra intent JSON (heuristics first). Set false for edge-case routing.
DISABLE_INTENT_LLM_REFINEMENT=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ENABLE_SEMANTIC_RETRIEVAL=true
ENABLE_PGVECTOR_RETRIEVAL=false
PGVECTOR_TABLE=guide_api_verse_embedding_index
PGVECTOR_EMBEDDING_DIM=1536
PGVECTOR_PROBES=10
DISABLE_ALL_QUOTAS=false
ASK_LIMIT_FREE_DAILY=3
ASK_LIMIT_PLUS_DAILY=0
ASK_LIMIT_PRO_DAILY=0
ASK_LIMIT_FREE_MONTHLY=100
ASK_LIMIT_PLUS_MONTHLY=200
ASK_LIMIT_PRO_MONTHLY=500
ENABLE_FREE_DEEP_MODE=false
ASK_LIMIT_PLUS_DEEP_MONTHLY=40
ASK_LIMIT_PRO_DEEP_MONTHLY=180

# Per-plan LLM output token caps (controls cost per ask)
MAX_OUTPUT_TOKENS_FREE=500
MAX_OUTPUT_TOKENS_PLUS=800
MAX_OUTPUT_TOKENS_PRO=1200

# Per-plan retrieval context verse limits
MAX_CONTEXT_VERSES_FREE=3
MAX_CONTEXT_VERSES_PLUS=5
MAX_CONTEXT_VERSES_PRO=6

# Hard caps to prevent runaway LLM cost
MAX_ASK_INPUT_CHARS=2200
MAX_ASK_ACTIONS=3
MAX_VERSE_REFERENCES=3

# Razorpay Payment Settings (for subscription payments)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Pricing in smallest currency unit (paise for INR, cents for USD)
SUBSCRIPTION_PRICE_PLUS_INR=19900
SUBSCRIPTION_PRICE_PLUS_USD=349
SUBSCRIPTION_PRICE_PRO_INR=49900
SUBSCRIPTION_PRICE_PRO_USD=849

# Optional: Google Search Console URL-prefix verification token
# Example: google-site-verification=abc123 from Search Console HTML tag method
GOOGLE_SITE_VERIFICATION=
